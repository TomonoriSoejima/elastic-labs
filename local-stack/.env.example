# Elastic Stack Version
STACK_VERSION=8.18.3

# Elasticsearch Configuration
ES_CONTAINER_NAME=es-local
ES_PORT=9200
ES_HEAP=1g

# Kibana Configuration
KB_CONTAINER_NAME=kb-local
KB_PORT=5601

# Security Configuration (for docker-compose.security.yml)
ELASTIC_PASSWORD=changeme

# Encryption Keys (for Kibana - required for detection rules, alerts, etc.)
ENCRYPTION_KEY_ESO=min-32-char-string-for-encryption-key-here-12345
ENCRYPTION_KEY_REPORTING=min-32-char-string-for-reporting-key-here-abcde
ENCRYPTION_KEY_SECURITY=min-32-char-string-for-security-key-here-fghij

# Note: For production, generate secure keys using:
# docker run --rm docker.elastic.co/kibana/kibana:8.18.3 bin/kibana-encryption-keys generate
